{
  "outputDirectory": "dist",
  "functions": {
    "api/refresh-weather-cache.js": {
      "maxDuration": 60,
      "includeFiles": "src/data/cityCoordinates.json"
    }
  },
  "crons": [
    {
      "path": "/api/refresh-weather-cache",
      "schedule": "0 0 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/data/(.*).geojson",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
