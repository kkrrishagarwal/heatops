    "NDBI": {
      "term": "NDBI",
      "definition": "Normalized Difference Built-up Index (urban/concrete)"
    },
    "NDWI": {
      "term": "NDWI",
      "definition": "Normalized Water Index (water bodies)"
    },
    "UHI": {
      "term": "UHI",
      "definition": "Urban Heat Island effect in cities"
    },
    "ENSO": {
      "term": "ENSO",
      "definition": "El Niño Southern Oscillation climate pattern"
    },
    "IOD": {
      "term": "IOD",
      "definition": "Indian Ocean Dipole monsoon driver"
    },
    "MJO": {
      "term": "MJO",
      "definition": "Madden-Julian Oscillation atmospheric waves"
    }
